		{
			"name": "Create Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "b3446ed8-98de-432c-865d-c67bd9fdccd0",
						"exec": [
							"pm.test(\"Successful POST request\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([201, 202]);",
							"    var json = JSON.parse(responseBody);",
							"    postman.setEnvironmentVariable(\"todo_id\", json.id);",
							"    postman.setEnvironmentVariable(\"todo_rev\", json.rev);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"type": "text",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"category\": \"shopping\",\n  \"text\": \"Don't forget the milk\",\n  \"status\": \"TODO\",\n  \"tags\": [\n    \"groceries\",\n    \"food\"\n  ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{host}}/todo",
					"host": [
						"{{host}}"
					],
					"path": [
						"todo"
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Todo",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "6f6998f5-8371-4c06-bc2d-b606acf46b1c",
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"    var json = JSON.parse(responseBody);",
							"    postman.setEnvironmentVariable(\"todo_id\", json.id);",
							"    postman.setEnvironmentVariable(\"todo_rev\", json.rev);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Accept",
						"type": "text",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"rev\": \"{{todo_rev}}\",\n    \"text\": \"Don't forget the milk\",\n    \"status\": \"TODO\",\n    \"category\": \"shopping\",\n    \"tags\": [\n        \"groceries\",\n        \"food\"\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{host}}/todo/{{todo_id}}",
					"host": [
						"{{host}}"
					],
					"path": [
						"todo",
						"{{todo_id}}"
					]
				}
			},
			"response": []
		},
